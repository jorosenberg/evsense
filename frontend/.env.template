# EVsense scraper environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
# IMPORTANT: Wrap multi-line JSON values in single quotes as shown below.
# python-dotenv requires this when values contain {, }, or : characters.

# Firebase service account JSON (from Firebase Console → Project Settings → Service Accounts)
# Wrap the entire JSON in single quotes — no line breaks inside the value
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# NREL API key (free at https://developer.nrel.gov/signup/)
NREL_API_KEY=your_nrel_api_key_here
